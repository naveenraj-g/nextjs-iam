{
  "name": "better-auth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "pnpm dlx prisma generate --schema ./src/modules/server/prisma/schema/schema.prisma",
    "db:push": "pnpm dlx prisma db push --schema ./src/modules/server/prisma/schema/schema.prisma",
    "db:studio": "pnpm dlx prisma studio --schema ./src/modules/server/prisma/schema/schema.prisma",
    "auth:generate": "pnpm dlx @better-auth/cli generate --config ./src/modules/server/auth-provider/auth.ts --output ./prisma/schema/schema.prisma",
    "deps": "pnpm dlx madge src/modules --circular --extensions ts",
    "deps:graph": "madge src/modules --image deps.svg --extensions ts,tsx",
    "seed:admin-menu": "tsx --env-file=.env scripts/seed-admin-menu.ts"
  },

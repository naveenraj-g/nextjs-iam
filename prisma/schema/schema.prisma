
generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  username           String?
  displayUsername    String?
  twoFactorEnabled   Boolean?            @default(false)
  role               String?
  banned             Boolean?            @default(false)
  banReason          String?
  banExpires         DateTime?
  twofactors         TwoFactor[]
  members            Member[]
  invitations        Invitation[]
  oauthclients       OauthClient[]
  oauthrefreshtokens OauthRefreshToken[]
  oauthaccesstokens  OauthAccessToken[]
  oauthconsents      OauthConsent[]

  agenthosts            AgentHost[]
  agents                Agent[]
  agentcapabilitygrants AgentCapabilityGrant[]
  approvalrequests      ApprovalRequest[]

  teammembers TeamMember[]

  // RBAC relations
  userRoles            UserRole[]
  userPermissionCaches UserPermissionCache[]

  @@unique([email])
  @@map("user")
  @@unique([username])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?
  impersonatedBy       String?
  oauthrefreshtokens   OauthRefreshToken[]
  oauthaccesstokens    OauthAccessToken[]

  activeTeamId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]

  teams Team[]

  // RBAC relations
  roles                Role[]
  userRoles            UserRole[]
  userPermissionCaches UserPermissionCache[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  teamId String?

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model OauthClient {
  id                      String              @id
  clientId                String
  clientSecret            String?
  disabled                Boolean?            @default(false)
  skipConsent             Boolean?
  enableEndSession        Boolean?
  subjectType             String?
  scopes                  String[]
  userId                  String?
  user                    User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime?
  updatedAt               DateTime?
  name                    String?
  uri                     String?
  icon                    String?
  contacts                String[]
  tos                     String?
  policy                  String?
  softwareId              String?
  softwareVersion         String?
  softwareStatement       String?
  redirectUris            String[]
  postLogoutRedirectUris  String[]
  tokenEndpointAuthMethod String?
  grantTypes              String[]
  responseTypes           String[]
  public                  Boolean?
  type                    String?
  requirePKCE             Boolean?
  referenceId             String?
  metadata                Json?
  oauthrefreshtokens      OauthRefreshToken[]
  oauthaccesstokens       OauthAccessToken[]
  oauthconsents           OauthConsent[]

  @@unique([clientId])
  @@map("oauthClient")
}

model OauthRefreshToken {
  id                String             @id
  token             String
  clientId          String
  oauthclient       OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId         String?
  session           Session?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId       String?
  expiresAt         DateTime?
  createdAt         DateTime?
  revoked           DateTime?
  authTime          DateTime?
  scopes            String[]
  oauthaccesstokens OauthAccessToken[]

  @@map("oauthRefreshToken")
}

model OauthAccessToken {
  id                String             @id
  token             String?
  clientId          String
  oauthclient       OauthClient        @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId         String?
  session           Session?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId            String?
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId       String?
  refreshId         String?
  oauthrefreshtoken OauthRefreshToken? @relation(fields: [refreshId], references: [id], onDelete: Cascade)
  expiresAt         DateTime?
  createdAt         DateTime?
  scopes            String[]

  @@unique([token])
  @@map("oauthAccessToken")
}

model OauthConsent {
  id          String      @id
  clientId    String
  oauthclient OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?
  scopes      String[]
  createdAt   DateTime?
  updatedAt   DateTime?

  @@map("oauthConsent")
}

model Apikey {
  id                  String    @id
  configId            String    @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?  @default(true)
  rateLimitEnabled    Boolean?  @default(true)
  rateLimitTimeWindow Int?      @default(86400000)
  rateLimitMax        Int?      @default(10)
  requestCount        Int?      @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?
  metadata            String?

  @@index([configId])
  @@index([referenceId])
  @@index([key])
  @@map("apikey")
}

model AgentHost {
  id                       String            @id
  name                     String?
  userId                   String?
  user                     User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultCapabilities      String?
  publicKey                String?
  kid                      String?
  jwksUrl                  String?
  enrollmentTokenHash      String?
  enrollmentTokenExpiresAt DateTime?
  status                   String            @default("active")
  activatedAt              DateTime?
  expiresAt                DateTime?
  lastUsedAt               DateTime?
  createdAt                DateTime
  updatedAt                DateTime
  agents                   Agent[]
  approvalrequests         ApprovalRequest[]

  @@index([userId])
  @@index([kid])
  @@index([enrollmentTokenHash])
  @@index([status])
  @@map("agentHost")
}

model Agent {
  id                    String                 @id
  name                  String
  userId                String?
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostId                String
  agenthost             AgentHost              @relation(fields: [hostId], references: [id], onDelete: Cascade)
  status                String                 @default("active")
  mode                  String                 @default("delegated")
  publicKey             String
  kid                   String?
  jwksUrl               String?
  lastUsedAt            DateTime?
  activatedAt           DateTime?
  expiresAt             DateTime?
  metadata              String?
  createdAt             DateTime
  updatedAt             DateTime
  agentcapabilitygrants AgentCapabilityGrant[]
  approvalrequests      ApprovalRequest[]

  @@index([userId])
  @@index([hostId])
  @@index([status])
  @@index([kid])
  @@map("agent")
}

model AgentCapabilityGrant {
  id          String    @id
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability  String
  deniedBy    String?
  user        User?     @relation(fields: [deniedBy], references: [id], onDelete: Cascade)
  grantedBy   String?
  expiresAt   DateTime?
  createdAt   DateTime
  updatedAt   DateTime
  status      String    @default("active")
  reason      String?
  constraints String?

  @@index([agentId])
  @@index([capability])
  @@index([grantedBy])
  @@index([status])
  @@map("agentCapabilityGrant")
}

model ApprovalRequest {
  id                         String     @id
  method                     String
  agentId                    String?
  agent                      Agent?     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  hostId                     String?
  agenthost                  AgentHost? @relation(fields: [hostId], references: [id], onDelete: Cascade)
  userId                     String?
  user                       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  capabilities               String?
  status                     String     @default("pending")
  userCodeHash               String?
  loginHint                  String?
  bindingMessage             String?
  clientNotificationToken    String?
  clientNotificationEndpoint String?
  deliveryMode               String?
  interval                   Int
  lastPolledAt               DateTime?
  expiresAt                  DateTime
  createdAt                  DateTime
  updatedAt                  DateTime

  @@index([agentId])
  @@index([hostId])
  @@index([userId])
  @@index([status])
  @@map("approvalRequest")
}

model Team {
  id             String       @id
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime
  updatedAt      DateTime?    @updatedAt
  teammembers    TeamMember[]

  @@index([organizationId])
  @@map("team")
}

model TeamMember {
  id        String    @id
  teamId    String
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime?

  @@index([teamId])
  @@index([userId])
  @@map("teamMember")
}


////////////////////////////////////////////////////////////////////////////

// Custom Schemas for RBAC

// ------------------------------------------------------------------ //
// Enums
// ------------------------------------------------------------------ //

enum PermissionEffect {
  ALLOW
  DENY
}

enum MenuNodeType {
  GROUP
  ITEM
}

// ------------------------------------------------------------------ //
// App — represents a module / application (e.g. "telemedicine", "admin")
// ------------------------------------------------------------------ //

model App {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions     Permission[]
  menus           AppMenuNode[]
  actions         AppAction[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@index([deletedAt])
  @@map("app")
}

// ------------------------------------------------------------------ //
// Role — org-scoped, supports hierarchy via parentId
// null organizationId = system/global role template
// ------------------------------------------------------------------ //

model Role {
  id             String        @id @default(cuid())
  name           String
  slug           String
  description    String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Role?         @relation("RoleHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       Role[]        @relation("RoleHierarchy")
  deletedAt      DateTime?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("role")
}

// ------------------------------------------------------------------ //
// UserRole — user can hold multiple roles per organization
// ------------------------------------------------------------------ //

model UserRole {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy     String?      // userId of the admin who granted this role
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId, roleId])
  @@index([userId])
  @@index([organizationId])
  @@index([roleId])
  @@map("userRole")
}

// ------------------------------------------------------------------ //
// Permission — atomic capability unit
// name is globally unique: "<resource>.<action>" e.g. "patient.read"
// appId is optional: null = cross-app, set = scoped to one app
// ------------------------------------------------------------------ //

model Permission {
  id          String    @id @default(cuid())
  name        String    @unique  // e.g. "patient.read"
  resource    String             // e.g. "patient"
  action      String             // e.g. "read" | "create" | "update" | "delete"
  description String?
  appId       String?
  app         App?      @relation(fields: [appId], references: [id], onDelete: SetNull)
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions   RolePermission[]
  menuPermissions   MenuPermission[]
  actionPermissions ActionPermission[]

  @@index([resource])
  @@index([appId])
  @@index([resource, action])
  @@index([deletedAt])
  @@map("permission")
}

// ------------------------------------------------------------------ //
// RolePermission — ALLOW / DENY mapping with optional app scope
// appId = null  → effect applies across all apps
// appId = <id>  → effect applies only when evaluating for that app
// No unique constraint (intentional): allows a role to have both a
// global ALLOW and an app-specific DENY for the same permission.
// Resolution engine: DENY always wins over ALLOW.
// ------------------------------------------------------------------ //

model RolePermission {
  id           String           @id @default(cuid())
  roleId       String
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  effect       PermissionEffect @default(ALLOW)
  appId        String?
  app          App?             @relation(fields: [appId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([roleId])
  @@index([permissionId])
  @@index([roleId, permissionId])
  @@index([appId])
  @@map("rolePermission")
}

// ------------------------------------------------------------------ //
// AppMenuNode — hierarchical menu tree per app
// ------------------------------------------------------------------ //

model AppMenuNode {
  id        String        @id @default(cuid())
  appId     String
  app       App           @relation(fields: [appId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    AppMenuNode?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  AppMenuNode[] @relation("MenuTree")
  label     String
  slug      String
  icon      String?
  href      String?
  order     Int           @default(0)
  type      MenuNodeType  @default(ITEM)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  menuPermissions MenuPermission[]

  @@unique([appId, slug])
  @@index([appId])
  @@index([parentId])
  @@map("appMenuNode")
}

// ------------------------------------------------------------------ //
// MenuPermission — which permission(s) gate a menu node
// A node is visible if the user has ANY of its required permissions.
// ------------------------------------------------------------------ //

model MenuPermission {
  id           String      @id @default(cuid())
  menuNodeId   String
  menuNode     AppMenuNode @relation(fields: [menuNodeId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([menuNodeId, permissionId])
  @@index([menuNodeId])
  @@index([permissionId])
  @@map("menuPermission")
}

// ------------------------------------------------------------------ //
// AppAction — a named operation (UI button or API call) per app
// ------------------------------------------------------------------ //

model AppAction {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  name        String   // e.g. "create_patient"
  label       String   // e.g. "Create Patient"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actionPermissions ActionPermission[]

  @@unique([appId, name])
  @@index([appId])
  @@map("appAction")
}

// ------------------------------------------------------------------ //
// ActionPermission — which permission(s) gate an action
// ------------------------------------------------------------------ //

model ActionPermission {
  id           String     @id @default(cuid())
  actionId     String
  action       AppAction  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([actionId, permissionId])
  @@index([actionId])
  @@index([permissionId])
  @@map("actionPermission")
}

// ------------------------------------------------------------------ //
// UserPermissionCache — denormalized resolved permission set
// Keyed by (userId, organizationId, appId).
// appId = null → cached for all apps combined.
// The service must invalidate this whenever roles or rolePermissions change.
// ------------------------------------------------------------------ //

model UserPermissionCache {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appId          String?
  permissions    Json         // { allow: string[], deny: string[] }
  computedAt     DateTime     @default(now())
  expiresAt      DateTime

  @@index([userId, organizationId, appId])
  @@index([expiresAt])
  @@map("userPermissionCache")
}